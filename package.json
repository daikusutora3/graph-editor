{
  "name": "graph-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first browser app for creating, editing, arranging, and exporting graph theory diagrams.",
  "license": "MIT",
  "homepage": "https://graph-editor.daikusutora3.workers.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daikusutora3/graph-editor.git"
  },
  "bugs": {
    "url": "https://github.com/daikusutora3/graph-editor/issues"
  },
  "keywords": [
    "graph-theory",
    "graph-editor",
    "graph-visualization",
    "cytoscape",
    "nextjs"
  ],
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "bun run tests/verification/run-all.ts",
    "check": "tsc --noEmit && oxlint . && prettier . --check && bun run test",
    "check:all": "bun run check && bun run build && bun run tests/verification/release.ts"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "cytoscape": "3.33.3",
    "jotai": "2.20.0",
    "lucide-react": "1.16.0",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "oxlint": "1.65.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
