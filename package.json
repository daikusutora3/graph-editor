{
  "name": "graph-editor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "verify:core": "bun run scripts/verify-graph-core.ts",
    "verify:samples": "bun run scripts/verify-samples.ts",
    "verify:layouts": "bun run scripts/verify-layouts.ts",
    "verify:architecture": "bun run scripts/verify-architecture.ts",
    "verify:deployment": "bun run scripts/verify-deployment-cost-guards.ts",
    "verify:editor": "bun run scripts/verify-editor-state.ts",
    "verify:io": "bun run scripts/verify-io-contracts.ts",
    "verify:bundle": "bun run scripts/verify-bundle-budget.ts",
    "verify:build": "next build",
    "check": "tsc --noEmit && oxlint . && prettier . --check && bun run verify:core && bun run verify:samples && bun run verify:layouts && bun run verify:architecture && bun run verify:deployment && bun run verify:editor && bun run verify:io",
    "check:all": "bun run check && bun run verify:build && bun run verify:bundle"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "cytoscape": "3.33.3",
    "jotai": "2.20.0",
    "lucide-react": "1.16.0",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "oxlint": "1.65.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
